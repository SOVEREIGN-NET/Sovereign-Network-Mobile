{
  "name": "SovereignNetworkMobile",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "prestart": "node scripts/generate-config.js",
    "start": "react-native start",
    "preandroid": "node scripts/generate-config.js",
    "android": "react-native run-android",
    "preios": "node scripts/generate-config.js",
    "ios": "react-native run-ios",
    "prebuild:android": "node scripts/generate-config.js",
    "build:android": "cd android && ./gradlew assembleRelease && cd ..",
    "prebuild:android:aab": "node scripts/generate-config.js",
    "build:android:aab": "cd android && ./gradlew bundleRelease && cd ..",
    "prebuild:ios": "node scripts/generate-config.js",
    "build:ios": "xcodebuild -workspace ios/SovereignNetworkMobile.xcworkspace -scheme SovereignNetworkMobile -configuration Release",
    "prebundle:android": "node scripts/generate-config.js",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "prebundle:ios": "node scripts/generate-config.js",
    "bundle:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
    "lint": "eslint .",
    "test": "jest",
    "clean:bundles": "rm -f ios/main.jsbundle ios/main.jsbundle.map android/app/src/main/assets/index.android.bundle android/app/src/main/assets/index.android.bundle.map",
    "version:bump": "./scripts/bump-version.sh",
    "version:bump:build": "./scripts/bump-version.sh build",
    "version:bump:patch": "./scripts/bump-version.sh patch",
    "version:bump:minor": "./scripts/bump-version.sh minor",
    "version:bump:major": "./scripts/bump-version.sh major"
  },
  "dependencies": {
    "-": "^0.0.1",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-navigation/bottom-tabs": "^7.6.0",
    "@react-navigation/native": "^7.1.19",
    "@react-navigation/native-stack": "^7.6.0",
    "react": "19.1.1",
    "react-native": "0.82.1",
    "react-native-keychain": "^10.0.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-qrcode-svg": "^6.3.16",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.18.0",
    "react-native-svg": "^15.15.3",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.2",
    "@react-native-community/cli-platform-android": "20.1.2",
    "@react-native-community/cli-platform-ios": "20.1.2",
    "@react-native/babel-preset": "0.82.1",
    "@react-native/eslint-config": "0.82.1",
    "@react-native/metro-config": "0.82.1",
    "@react-native/typescript-config": "0.82.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.1",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^5.1.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
