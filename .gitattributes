# Auto detect text files and enforce LF line endings for cross-platform compatibility
* text=auto eol=lf

# Shell scripts must always have LF line endings (WSL/Unix requires it)
*.sh text eol=lf
gradlew text eol=lf

# Batch files should keep CRLF for native Windows compatibility
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - don't touch
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.keystore binary