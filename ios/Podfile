# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# Firebase static frameworks cause modular header conflicts with RN 0.82; keep as dynamic frameworks
$RNFirebaseAsStaticFramework = false

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'SovereignNetworkMobile' do
  config = use_native_modules!

  # Firebase Swift pods need modular headers on their C deps when linked statically with RN
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'FirebaseCrashlytics', :modular_headers => true
  pod 'FirebaseSessions', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseRemoteConfigInterop', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'nanopb', :modular_headers => true

  # CBOR serialization for ZHTP protocol
  pod 'SwiftCBOR', '~> 0.6.0'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Firebase build settings
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
          '$(inherited)',
          'FIREBASE_ANALYTICS_COLLECTION_ENABLED=1',
        ]
      end
    end

    # Patch React Native TextInput to disable Safari password autofill
    # Prevents crash in _SFPasswordViewController when password fields are present
    react_native_path = File.join(Pod::Config.instance.installation_root, config[:reactNativePath])
    rct_text_input_path = File.join(react_native_path, 'React/Views/RCTTextInputView.m')

    if File.exist?(rct_text_input_path)
      content = File.read(rct_text_input_path)

      # Check if patch already applied
      unless content.include?('textInputView.textContentType = UITextContentTypeOneTimeCode')
        # Find becomeFirstResponder method and add patch before it
        patch = 'textInputView.textContentType = UITextContentTypeOneTimeCode;'
        if content.gsub!(/(\[.*?becomeFirstResponder\])/, "#{patch}\n\\1")
          File.write(rct_text_input_path, content)
          puts "[PATCH] Applied Safari autofill disable to RCTTextInputView.m"
        end
      end
    end
  end
end
